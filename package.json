{
  "name": "n8n-nodes-revenium-anthropic",
  "version": "0.1.0",
  "description": "n8n community node for Anthropic ChatCompletion with automatic Revenium usage tracking",
  "type": "module",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "anthropic",
    "revenium",
    "metering",
    "usage-tracking",
    "ai",
    "claude",
    "langchain",
    "automation"
  ],
  "license": "MIT",
  "homepage": "https://github.com/revenium/revenium-middleware-anthropic-n8n",
  "author": {
    "name": "Revenium",
    "email": "support@revenium.io"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/revenium/revenium-middleware-anthropic-n8n.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes src --ext .ts,.js",
    "lintfix": "eslint nodes src --ext .ts,.js --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit tests/*.test.ts",
    "test:integration": "vitest run --config tests/integration/vitest.integration.config.ts",
    "test:integration:watch": "vitest --config tests/integration/vitest.integration.config.ts",
    "test:all": "npm run test:unit && npm run test:integration",
    "prepublishOnly": "npm run build && npm run lint"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ReveniumAnthropic.credentials.js"
    ],
    "nodes": [
      "dist/nodes/ReveniumAnthropicChatModel/ReveniumAnthropicChatModel.node.js",
      "dist/nodes/ReveniumAIAgent/ReveniumAIAgent.node.js"
    ]
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/request-promise-native": "^1.0.21",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "eslint": "^9.18.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.2",
    "gulp": "^5.0.1",
    "n8n-core": "~1.103.1",
    "n8n-workflow": "~1.101.0",
    "prettier": "^3.4.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@langchain/anthropic": "^0.3.14",
    "@langchain/core": "^0.3.57",
    "dotenv": "^16.5.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3"
  },
  "overrides": {
    "form-data": "^4.0.4"
  }
}
